{
  "expo": {
    "name": "SmartBus Driver",
    "slug": "smartbus-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1D4ED8"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartbus.driver",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "SmartBus needs access to your location to track bus position.",
        "NSLocationWhenInUseUsageDescription": "SmartBus needs access to your location to track bus position.",
        "NSCameraUsageDescription": "SmartBus needs camera access to scan student QR codes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1D4ED8"
      },
      "package": "com.smartbus.driver",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow SmartBus to use your location."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SmartBus to access your camera."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1D4ED8"
        }
      ]
    ]
  }
}
